#!/usr/bin/env bash
# sendient-claude — Sendient wrapper for Claude Code
# Displays the SREE methodology banner, then launches the real claude binary.

set -euo pipefail

# --- Find the real claude binary ---
# Prefer the native install location, then fall back to PATH search
SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
NATIVE_CLAUDE="$HOME/.local/bin/claude"

find_real_claude() {
  # 1. Native install (preferred)
  if [ -x "$NATIVE_CLAUDE" ]; then
    echo "$NATIVE_CLAUDE"
    return 0
  fi
  # 2. Search PATH, skipping our own directory
  local IFS=':'
  for dir in $PATH; do
    [ "$dir" = "$SELF_DIR" ] && continue
    if [ -x "$dir/claude" ]; then
      echo "$dir/claude"
      return 0
    fi
  done
  return 1
}

REAL_CLAUDE="$(find_real_claude)" || {
  echo "Error: Could not find the real Claude Code binary." >&2
  echo "Install it first: https://code.claude.com/docs/setup" >&2
  exit 1
}

# --- Only show the banner for interactive sessions (no args or interactive flags) ---
# Skip banner when piped, used with -p/--print, or in non-interactive contexts
# Skip banner when running under the agent-runner profile (non-interactive)
show_banner=true
if [ ! -t 1 ]; then
  show_banner=false
fi
for arg in "$@"; do
  case "$arg" in
    -p|--print|--json|--version|-v) show_banner=false; break ;;
  esac
done
if [[ -f "${HOME}/.sendient/profile" ]]; then
  _sendient_profile="$(cat "${HOME}/.sendient/profile")"
  if [[ "${_sendient_profile}" == "agent-runner" ]]; then
    show_banner=false
  fi
  unset _sendient_profile
fi

if $show_banner; then
  # Try python3 first, then python, skip banner if neither available
  PYTHON=""
  if command -v python3 >/dev/null 2>&1; then
    PYTHON=python3
  elif command -v python >/dev/null 2>&1; then
    PYTHON=python
  fi

  if [ -n "$PYTHON" ]; then
    "$PYTHON" "$SELF_DIR/banner.py" 2>/dev/null || true
  fi
fi

# --- Hand off to the real claude ---
exec "$REAL_CLAUDE" "$@"
