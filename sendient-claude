#!/usr/bin/env bash
# sendient-claude — Sendient wrapper for Claude Code
# Displays the SREE methodology banner, then launches the real claude binary.

set -euo pipefail

# --- Find the real claude binary (skip our own directory) ---
SELF_DIR="$(cd "$(dirname "$0")" && pwd)"

find_real_claude() {
  local IFS=':'
  for dir in $PATH; do
    [ "$dir" = "$SELF_DIR" ] && continue
    if [ -x "$dir/claude" ]; then
      echo "$dir/claude"
      return 0
    fi
  done
  return 1
}

REAL_CLAUDE="$(find_real_claude)" || {
  echo "Error: Could not find the real Claude Code binary." >&2
  echo "Install it first: https://docs.anthropic.com/en/docs/claude-code" >&2
  exit 1
}

# --- Only show the banner for interactive sessions (no args or interactive flags) ---
# Skip banner when piped, used with -p/--print, or in non-interactive contexts
show_banner=true
if [ ! -t 1 ]; then
  show_banner=false
fi
for arg in "$@"; do
  case "$arg" in
    -p|--print|--json|--version|-v) show_banner=false; break ;;
  esac
done

if $show_banner; then
  # Colours (gracefully degrade if tput unavailable)
  if command -v tput >/dev/null 2>&1 && [ "${TERM:-dumb}" != "dumb" ]; then
    BOLD="$(tput bold)"
    DIM="$(tput dim)"
    CYAN="$(tput setaf 6)"
    WHITE="$(tput setaf 7)"
    YELLOW="$(tput setaf 3)"
    RESET="$(tput sgr0)"
  else
    BOLD="" DIM="" CYAN="" WHITE="" YELLOW="" RESET=""
  fi

  printf '\n'
  printf '%s╭─────────────────────────────────────────────────╮%s\n' "$DIM" "$RESET"
  printf '%s│%s  %sSendient AI — SREE Methodology%s                 %s│%s\n' "$DIM" "$RESET" "${BOLD}${CYAN}" "$RESET" "$DIM" "$RESET"
  printf '%s│%s                                                 %s│%s\n' "$DIM" "$RESET" "$DIM" "$RESET"
  printf '%s│%s  %s/scope%s    → Define what you want to achieve    %s│%s\n' "$DIM" "$RESET" "${BOLD}${YELLOW}" "$RESET" "$DIM" "$RESET"
  printf '%s│%s  %s/refine%s   → Clarify requirements & constraints %s│%s\n' "$DIM" "$RESET" "${BOLD}${YELLOW}" "$RESET" "$DIM" "$RESET"
  printf '%s│%s  %s/execute%s  → Implement the solution             %s│%s\n' "$DIM" "$RESET" "${BOLD}${YELLOW}" "$RESET" "$DIM" "$RESET"
  printf '%s│%s  %s/evaluate%s → Review, confirm, document, merge   %s│%s\n' "$DIM" "$RESET" "${BOLD}${YELLOW}" "$RESET" "$DIM" "$RESET"
  printf '%s│%s                                                 %s│%s\n' "$DIM" "$RESET" "$DIM" "$RESET"
  printf '%s│%s  %sStart any session with %s/scope%s, or pick up%s      %s│%s\n' "$DIM" "$RESET" "$DIM" "${WHITE}" "$DIM" "$RESET" "$DIM" "$RESET"
  printf '%s│%s  %swhere you left off with %s/refine%s, or %s/execute%s.%s  %s│%s\n' "$DIM" "$RESET" "$DIM" "${WHITE}" "$DIM" "${WHITE}" "$DIM" "$RESET" "$DIM" "$RESET"
  printf '%s╰─────────────────────────────────────────────────╯%s\n' "$DIM" "$RESET"
fi

# --- Hand off to the real claude ---
exec "$REAL_CLAUDE" "$@"
