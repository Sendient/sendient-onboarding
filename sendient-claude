#!/usr/bin/env bash
# sendient-claude вЂ” Sendient wrapper for Claude Code
# Displays the SREE methodology banner, then launches the real claude binary.

set -euo pipefail

# --- Find the real claude binary ---
# Prefer the native install location, then fall back to PATH search
SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
NATIVE_CLAUDE="$HOME/.local/bin/claude"

find_real_claude() {
  # 1. Native install (preferred)
  if [ -x "$NATIVE_CLAUDE" ]; then
    echo "$NATIVE_CLAUDE"
    return 0
  fi
  # 2. Search PATH, skipping our own directory
  local IFS=':'
  for dir in $PATH; do
    [ "$dir" = "$SELF_DIR" ] && continue
    if [ -x "$dir/claude" ]; then
      echo "$dir/claude"
      return 0
    fi
  done
  return 1
}

REAL_CLAUDE="$(find_real_claude)" || {
  echo "Error: Could not find the real Claude Code binary." >&2
  echo "Install it first: https://code.claude.com/docs/setup" >&2
  exit 1
}

# --- Only show the banner for interactive sessions (no args or interactive flags) ---
# Skip banner when piped, used with -p/--print, or in non-interactive contexts
show_banner=true
if [ ! -t 1 ]; then
  show_banner=false
fi
for arg in "$@"; do
  case "$arg" in
    -p|--print|--json|--version|-v) show_banner=false; break ;;
  esac
done

if $show_banner; then
  # Colours (gracefully degrade if tput unavailable)
  if command -v tput >/dev/null 2>&1 && [ "${TERM:-dumb}" != "dumb" ]; then
    BOLD="$(tput bold)"
    DIM="$(tput dim)"
    CYAN="$(tput setaf 6)"
    WHITE="$(tput setaf 7)"
    YELLOW="$(tput setaf 3)"
    RESET="$(tput sgr0)"
  else
    BOLD="" DIM="" CYAN="" WHITE="" YELLOW="" RESET=""
  fi

  printf '\n'
  printf '%sв•­в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•®%s\n' "$DIM" "$RESET"
  printf '%sв”‚%s  %sSendient AI вЂ” SREE Methodology%s                 %sв”‚%s\n' "$DIM" "$RESET" "${BOLD}${CYAN}" "$RESET" "$DIM" "$RESET"
  printf '%sв”‚%s                                                 %sв”‚%s\n' "$DIM" "$RESET" "$DIM" "$RESET"
  printf '%sв”‚%s  %s/scope%s    в†’ Define what you want to achieve    %sв”‚%s\n' "$DIM" "$RESET" "${BOLD}${YELLOW}" "$RESET" "$DIM" "$RESET"
  printf '%sв”‚%s  %s/refine%s   в†’ Clarify requirements & constraints %sв”‚%s\n' "$DIM" "$RESET" "${BOLD}${YELLOW}" "$RESET" "$DIM" "$RESET"
  printf '%sв”‚%s  %s/execute%s  в†’ Implement the solution             %sв”‚%s\n' "$DIM" "$RESET" "${BOLD}${YELLOW}" "$RESET" "$DIM" "$RESET"
  printf '%sв”‚%s  %s/evaluate%s в†’ Review, confirm, document, merge   %sв”‚%s\n' "$DIM" "$RESET" "${BOLD}${YELLOW}" "$RESET" "$DIM" "$RESET"
  printf '%sв”‚%s                                                 %sв”‚%s\n' "$DIM" "$RESET" "$DIM" "$RESET"
  printf '%sв”‚%s  %sStart any session with %s/scope%s, or pick up%s      %sв”‚%s\n' "$DIM" "$RESET" "$DIM" "${WHITE}" "$DIM" "$RESET" "$DIM" "$RESET"
  printf '%sв”‚%s  %swhere you left off with %s/refine%s, or %s/execute%s.%s  %sв”‚%s\n' "$DIM" "$RESET" "$DIM" "${WHITE}" "$DIM" "${WHITE}" "$DIM" "$RESET" "$DIM" "$RESET"
  printf '%sв•°в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•Ї%s\n' "$DIM" "$RESET"
fi

# --- Hand off to the real claude ---
exec "$REAL_CLAUDE" "$@"
